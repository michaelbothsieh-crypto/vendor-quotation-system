generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vendor {
  id           String      @id @default(uuid())
  name         String
  taxId        String?
  contactName  String
  contactEmail String
  contactPhone String?
  address      String?
  quotations   Quotation[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// 報價範本：ADMIN 自訂工時角色欄位（名稱/費率/順序）與預設商務條件
model QuoteTemplate {
  id           String   @id @default(uuid())
  name         String
  isDefault    Boolean  @default(false)
  roles        Json // [{ key, label, rate }]，順序即陣列順序
  paymentTerms String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Quotation {
  id              String @id @default(uuid())
  quotationNumber String
  title           String
  vendorId        String
  vendor          Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  // 廠商快照：儲存當下複製，廠商日後異動/刪除不影響歷史報價單內容
  vendorName         String  @default("")
  vendorTaxId        String?
  vendorContactName  String  @default("")
  vendorContactEmail String  @default("")
  vendorContactPhone String?
  vendorAddress      String?

  status  String @default("DRAFT") // DRAFT | SENT | APPROVED | REJECTED
  taxRate Float  @default(0.05)
  roles   Json   @default("[]") // 角色定義與費率快照 [{ key, label, rate }]

  // 商務條件
  issueDate    DateTime  @default(now())
  validUntil   DateTime?
  paymentTerms String?
  notes        String?
  discount     Int       @default(0) // 整單折扣額（未稅前扣除）

  version           Int                 @default(1)
  isLatest          Boolean             @default(true)
  parentQuotationId String?             @unique
  parentQuotation   Quotation?          @relation("QuotationVersion", fields: [parentQuotationId], references: [id], onDelete: SetNull)
  childQuotation    Quotation?          @relation("QuotationVersion")
  categories        QuotationCategory[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([quotationNumber, version])
}

model QuotationCategory {
  id          String          @id @default(uuid())
  quotationId String
  quotation   Quotation       @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  name        String
  sortOrder   Int             @default(0)
  items       QuotationItem[]
}

model QuotationItem {
  id          String            @id @default(uuid())
  categoryId  String
  category    QuotationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  description String
  days        Json              @default("{}") // { [roleKey]: number }，一位小數
  note        String?
  sortOrder   Int               @default(0)
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("VIEWER") // ADMIN | EDITOR | VIEWER
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
