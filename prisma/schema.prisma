generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vendor {
  id           String      @id @default(uuid())
  name         String
  taxId        String?
  contactName  String
  contactEmail String
  contactPhone String?
  address      String?
  quotations   Quotation[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Quotation {
  id                String              @id @default(uuid())
  quotationNumber   String
  title             String
  vendorId          String
  vendor            Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  status            String              @default("DRAFT") // 狀態：草稿 (DRAFT), 已寄出 (SENT), 已核准 (APPROVED)
  taxRate           Float               @default(0.05)
  rdRate            Int                 @default(8000)
  pmRate            Int                 @default(6000)
  qcRate            Int                 @default(5000)
  integrationRate   Int                 @default(6500)
  version           Int                 @default(1)
  isLatest          Boolean             @default(true)
  parentQuotationId String?             @unique
  parentQuotation   Quotation?          @relation("QuotationVersion", fields: [parentQuotationId], references: [id], onDelete: SetNull)
  childQuotation    Quotation?          @relation("QuotationVersion")
  categories        QuotationCategory[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([quotationNumber, version])
}

model QuotationCategory {
  id          String          @id @default(uuid())
  quotationId String
  quotation   Quotation       @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  name        String
  sortOrder   Int             @default(0)
  items       QuotationItem[]
}

model QuotationItem {
  id              String            @id @default(uuid())
  categoryId      String
  category        QuotationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  description     String
  rdDays          Decimal           @default(0.0) @db.Decimal(10, 1)
  pmDays          Decimal           @default(0.0) @db.Decimal(10, 1)
  qcDays          Decimal           @default(0.0) @db.Decimal(10, 1)
  integrationDays Decimal           @default(0.0) @db.Decimal(10, 1)
  note            String?
  sortOrder       Int               @default(0)
}

model SystemSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("USER") // ADMIN | USER
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
